# Kaizen backend — environment configuration
# Copy to `.env` at the repo root (or export in your shell) and fill in real values.
# The worker inherits this env and passes it to each per-tenant Hermes process
# (worker_pool sets HERMES_HOME on top). Var names are grounded in the actual
# Hermes source (hermes_cli/runtime_provider.py, plugins/memory/honcho/client.py).

# =============================================================================
# 1. LLM PROVIDER  (REQUIRED for real LLM calls)
# =============================================================================
# We use the OpenAI perk. The API KEY comes from env; the MODEL is set per-tenant
# in each profile's config.yaml (model.default), written by render_home().
OPENAI_API_KEY=
# Optional: override the OpenAI-compatible base URL (leave blank for default).
OPENAI_BASE_URL=
# Optional: force a model/provider for oneshot-style runs (else config.yaml wins).
HERMES_INFERENCE_MODEL=
HERMES_INFERENCE_PROVIDER=openai
# --- Alternative provider (if not using OpenAI directly) ---
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=

# =============================================================================
# 2. MEMORY PROVIDER — Honcho Cloud  (REQUIRED: decision = Honcho now)
# =============================================================================
# Per-tenant workspace/peer is set per profile in honcho.json (workspace = brand_id),
# written by render_home(). These env vars provide the credentials + endpoint.
HONCHO_API_KEY=
HONCHO_BASE_URL=
# Optional:
# HONCHO_ENVIRONMENT=
# HONCHO_TIMEOUT=

# =============================================================================
# 3. CONVEX — data system-of-record + auth issuer  (REQUIRED)
# =============================================================================
# From `npx convex dev` output. Two distinct origins:
#   CONVEX_URL      → client/API origin (….convex.cloud)
#   CONVEX_SITE_URL → HTTP-actions origin (….convex.site) = the JWT issuer / JWKS host
CONVEX_URL=
CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# =============================================================================
# 4. AUTH — what FastAPI (kaizen/auth.py) verifies incoming JWTs against
# =============================================================================
# Derived from CONVEX_SITE_URL; verify iss + aud, take tenant_id from `sub`.
CONVEX_JWT_ISSUER=${CONVEX_SITE_URL}
CONVEX_JWKS_URL=${CONVEX_SITE_URL}/.well-known/jwks.json
CONVEX_JWT_AUDIENCE=convex

# =============================================================================
# 5. KAIZEN BACKEND
# =============================================================================
# Base dir for per-tenant HERMES_HOME profiles (provision_tenant base_dir).
# Local dev default below; in cloud this is a persistent volume (e.g. /opt/data/profiles).
KAIZEN_PROFILES_DIR=./.kaizen/profiles
KAIZEN_API_HOST=127.0.0.1
KAIZEN_API_PORT=8000

# =============================================================================
# 6. DEPLOY / CLOUD  — DEFERRED (CLAUDE.md rule 6: get it working locally first)
# =============================================================================
# NOT needed for local live testing. Add when we deploy (Approach A → volume box).
# CLOUDFLARE_API_TOKEN=
# REDIS_URL=            # only when we move IPC from stdout JSON-lines to Redis pub/sub
